# Triton model config for the ReefScan DINOv2-B classifier, served as the TensorRT fp16 engine.
# The batch dim is implicit (max_batch_size > 0), so input/output dims EXCLUDE batch.
name: "reefscan_dinov2"
platform: "tensorrt_plan"
max_batch_size: 64            # matches the engine's optimization profile (min1/opt32/max64)

input [
  {
    name: "pixel_values"
    data_type: TYPE_FP32
    dims: [ 3, 224, 224 ]
  }
]
output [
  {
    name: "logits"
    data_type: TYPE_FP32
    dims: [ 2 ]                # [healthy, bleached]
  }
]

# Dynamic batching: Triton coalesces concurrent single-image requests into batches server-side,
# trading a tiny queue delay for the ~7x batched throughput the serving curve shows.
dynamic_batching {
  preferred_batch_size: [ 8, 16, 32 ]
  max_queue_delay_microseconds: 1000
}

instance_group [
  {
    count: 1
    kind: KIND_GPU
  }
]
