# Copy to .env and fill in. Never commit .env.
# Each value is provided when its phase is reached (see CLAUDE.md).

# Supabase (Phase 5) — backend is SERVER-SIDE, so use the SERVICE_ROLE key here.
# Tables have RLS enabled (anon denied); service_role bypasses RLS. Never ships to the browser.
SUPABASE_URL=
SUPABASE_KEY=

# Cloudflare R2 (Phase 5) — S3-compatible
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# Hugging Face (Phase 3 weights + inference load)
HF_TOKEN=
HF_MODEL_REPO=

# Weights & Biases (Phase 3)
WANDB_API_KEY=
WANDB_PROJECT=reefscan

# Model version string logged to inference_logs
MODEL_VERSION=dinov2b-linearprobe-v0

# Frontend (Vercel) — point the Next.js app at the deployed backend Space.
# Set in the FRONTEND env (Vercel), not the backend. Unset => frontend uses local mock data.
NEXT_PUBLIC_REEFSCAN_API=
